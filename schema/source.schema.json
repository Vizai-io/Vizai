{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vizai.io/schema/source.schema.json",
  "title": "Source",
  "type": "object",
  "required": ["id", "title", "url", "type", "capturedAt"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "type": {
      "type": "string",
      "enum": [
        "website",
        "product-page",
        "service-page",
        "document",
        "email",
        "interview",
        "other"
      ]
    },
    "capturedAt": { "type": "string", "format": "date" },
    "notes": { "type": "string" },
    "factType": {
      "type": "string",
      "enum": ["customer_provided", "website_extracted", "human_approved"]
    }
  },
  "additionalProperties": false
}
